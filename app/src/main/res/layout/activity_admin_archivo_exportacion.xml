<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_export_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

        <TextView
            android:id="@+id/tvAdminExportDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_export_description"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <TextView
            android:id="@+id/tvAdminExportRetention"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/admin_export_retention_not_configured"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_archive_retention_label"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <EditText
            android:id="@+id/etAdminExportRetentionDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/admin_archive_retention_hint"
            android:inputType="number"
            android:maxLines="1" />

        <Button
            android:id="@+id/btnAdminExportSaveRetention"
            style="@style/Widget.ReservasApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_archive_retention_save" />

        <TextView
            android:id="@+id/tvAdminExportLastArchived"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_export_last_archived_default"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <TextView
            android:id="@+id/tvAdminExportOverlapWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/button_primary_fill"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvAdminExportFrom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/admin_export_from_label"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <Button
            android:id="@+id/btnAdminExportFrom"
            style="@style/Widget.ReservasApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_export_pick_from" />

        <TextView
            android:id="@+id/tvAdminExportTo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/admin_export_to_label"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <Button
            android:id="@+id/btnAdminExportTo"
            style="@style/Widget.ReservasApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_export_pick_to" />

        <Button
            android:id="@+id/btnAdminExportGenerate"
            style="@style/Widget.ReservasApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/admin_export_button" />

        <TextView
            android:id="@+id/tvAdminExportStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/admin_export_status_idle"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />
    </LinearLayout>
</ScrollView>
