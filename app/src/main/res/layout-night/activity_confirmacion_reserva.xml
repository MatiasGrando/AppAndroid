<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_asian_food"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvTituloConfirmacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/titulo_confirmacion"
            android:textColor="#F6E9C5"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFechaReserva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textColor="#D9D2C1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetalleConfirmacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="#D9D2C1"
            android:textSize="18sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPlatoPrincipal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="#D9101A24"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#37506A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/label_plato_principal"
                    android:textColor="#F6E9C5"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPlatoPrincipalNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:textColor="#F6E9C5"
                    android:textSize="26sp" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivPlatoPrincipal"
                    android:layout_width="128dp"
                    android:layout_height="128dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:background="#1E2D3B"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_food_main"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.ReservasApp.CircleImage"
                    app:strokeColor="#C99A61"
                    app:strokeWidth="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGuarnicion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#D9101A24"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#37506A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_guarnicion"
                        android:textColor="#F6E9C5"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGuarnicionNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#D2D9E4"
                        android:textSize="16sp" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivGuarnicion"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_marginStart="12dp"
                    android:background="#1E2D3B"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_side_dish"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.ReservasApp.CircleImage"
                    app:strokeColor="#C99A61"
                    app:strokeWidth="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPostre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#D9101A24"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#37506A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_postre"
                        android:textColor="#D2D9E4"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPostreNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#D2D9E4"
                        android:textSize="16sp" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivPostre"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_marginStart="12dp"
                    android:background="#1E2D3B"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_dessert"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.ReservasApp.CircleImage"
                    app:strokeColor="#C99A61"
                    app:strokeWidth="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnVolverMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_orange"
            android:paddingVertical="10dp"
            android:text="@string/volver_menu"
            android:textAllCaps="false"
            android:textColor="#F6E9C5"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>
