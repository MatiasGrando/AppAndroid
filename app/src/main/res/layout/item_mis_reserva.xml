<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/mis_reserva_card_background"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/mis_reserva_card_stroke"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFechaReserva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mis_reserva_header_background"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:textColor="@color/mis_reserva_header_text"
            android:textSize="25sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:id="@+id/rowGuarnicion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plato principal"
                        android:textColor="@color/mis_reserva_section_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPlatoPrincipalNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:maxLines="2"
                        android:textColor="@color/mis_reserva_item_text"
                        android:textSize="17sp" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivPlatoPrincipal"
                    android:layout_width="94dp"
                    android:layout_height="94dp"
                    android:background="@color/mis_reserva_image_background"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_food_main"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.ReservasApp.CircleImage"
                    app:strokeColor="@color/mis_reserva_image_stroke"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="4dp"
                android:background="@color/mis_reserva_card_stroke" />

            <LinearLayout
                android:id="@+id/rowGuarnicion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guarnición"
                        android:textColor="@color/mis_reserva_section_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGuarnicionNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:maxLines="2"
                        android:textColor="@color/mis_reserva_item_text"
                        android:textSize="17sp" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivGuarnicion"
                    android:layout_width="94dp"
                    android:layout_height="94dp"
                    android:background="@color/mis_reserva_image_background"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_side_dish"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.ReservasApp.CircleImage"
                    app:strokeColor="@color/mis_reserva_image_stroke"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <View
                android:id="@+id/dividerPostGuarnicion"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="4dp"
                android:background="@color/mis_reserva_card_stroke" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Postre"
                        android:textColor="@color/mis_reserva_section_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPostreNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:maxLines="2"
                        android:textColor="@color/mis_reserva_item_text"
                        android:textSize="17sp" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivPostre"
                    android:layout_width="94dp"
                    android:layout_height="94dp"
                    android:background="@color/mis_reserva_image_background"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_dessert"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.ReservasApp.CircleImage"
                    app:strokeColor="@color/mis_reserva_image_stroke"
                    app:strokeWidth="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
