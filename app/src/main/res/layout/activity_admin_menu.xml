<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/titulo_admin_menu"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/admin_menu_description"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="#33A84300"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvModoFormularioPlato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_menu_crear_plato"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/admin_menu_form_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_seccion"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/admin_menu_section_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <AutoCompleteTextView
                android:id="@+id/actvSeccionPlato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="@string/hint_nombre_seccion"
                android:inputType="none"
                android:paddingVertical="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/hint_nombre_plato"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <EditText
                android:id="@+id/etNombrePlato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="@string/hint_nombre_plato"
                android:inputType="textCapWords"
                android:maxLines="1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/admin_menu_detail_label"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/admin_menu_detail_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <EditText
                android:id="@+id/etDetallePlato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="top|start"
                android:hint="@string/hint_detalle_plato"
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="2" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/admin_menu_image_label"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/admin_menu_image_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <EditText
                android:id="@+id/etImagenUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="@string/hint_url_imagen"
                android:inputType="textUri" />

            <TextView
                android:id="@+id/tvGuarnicion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/label_guarnicion"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvGuarnicionHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/admin_menu_guarnicion_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutGuarnicionChecks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/cbGuarnicionSi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/si" />

                <CheckBox
                    android:id="@+id/cbGuarnicionNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="@string/no" />
            </LinearLayout>

            <Button
                android:id="@+id/btnCrearPlato"
                style="@style/Widget.ReservasApp.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/crear_plato" />

            <Button
                android:id="@+id/btnCancelarEdicionPlato"
                style="@style/Widget.ReservasApp.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/cancelar_edicion_plato"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="#1F000000"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/secciones_actuales"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/admin_menu_list_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <TextView
                android:id="@+id/tvEmptyMenuList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/admin_menu_empty_state"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:visibility="gone" />

            <ListView
                android:id="@+id/listSeccionesMenu"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp"
                android:paddingBottom="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnVolverMenuAdmin"
        style="@style/Widget.ReservasApp.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/volver_menu" />
</LinearLayout>
