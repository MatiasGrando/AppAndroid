<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/pedidos_por_dia_titulo"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

    <TextView
        android:id="@+id/tvFechaPedidosSeleccionada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/pedidos_por_dia_fecha_default"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

    <Button
        style="@style/Widget.ReservasApp.Button.Primary"
        android:id="@+id/btnSeleccionarFechaPedidos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/admin_menu_seleccionar_fecha" />

    <Button
        style="@style/Widget.ReservasApp.Button.Primary"
        android:id="@+id/btnGenerarResumenPedidos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/pedidos_por_dia_generar_resumen" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvResumenPedidos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="@string/pedidos_por_dia_sin_datos"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />
    </ScrollView>

</LinearLayout>
