<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_panel_title"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_panel_description"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <Button
            style="@style/Widget.ReservasApp.Button.Primary"
            android:id="@+id/btnConfigReservasAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/admin_panel_config_reservas" />

        <Button
            style="@style/Widget.ReservasApp.Button.Primary"
            android:id="@+id/btnConfigMenuFechaAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_menu_config_por_fecha" />

        <Button
            style="@style/Widget.ReservasApp.Button.Primary"
            android:id="@+id/btnAddMenuAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_panel_add_menu" />

        <Button
            style="@style/Widget.ReservasApp.Button.Primary"
            android:id="@+id/btnResumenPedidosDiaAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_panel_resumen_pedidos_dia" />

        <Button
            style="@style/Widget.ReservasApp.Button.Primary"
            android:id="@+id/btnDetallePedidosUsuariosAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_panel_detalle_pedidos_usuarios" />

        <Button
            style="@style/Widget.ReservasApp.Button.Primary"
            android:id="@+id/btnArchivoExportacionAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_panel_archivo_exportacion" />
    </LinearLayout>
</ScrollView>
