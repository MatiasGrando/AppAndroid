<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.App" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:colorBackground">@color/app_dark_background</item>
        <item name="colorOnBackground">@color/app_dark_on_background</item>
        <item name="colorSurface">@color/app_dark_surface</item>
        <item name="colorOnSurface">@color/app_dark_on_surface</item>
        <item name="buttonStyle">@style/Widget.ReservasApp.Button.Primary</item>
        <item name="materialButtonStyle">@style/Widget.ReservasApp.Button.MaterialPrimary</item>
        <item name="android:statusBarColor">@color/app_dark_surface</item>
        <item name="android:navigationBarColor">@color/app_dark_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.ReservasApp" parent="Theme.App">
        <item name="android:windowBackground">@drawable/landing_background</item>
    </style>
    <style name="Theme.ReservasApp.Launcher" parent="Theme.ReservasApp">
        <item name="android:windowBackground">@color/app_dark_background</item>
    </style>
</resources>
