<resources>
    <style name="ShapeAppearanceOverlay.ReservasApp.CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.ReservasApp.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_orange</item>
        <item name="android:backgroundTint">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/button_primary_text</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.ReservasApp.Button.MaterialPrimary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/button_primary_fill</item>
        <item name="android:textColor">@color/button_primary_text</item>
        <item name="iconTint">@color/button_primary_text</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.ReservasApp.Button.Home" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/home_cta_text</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="iconTint">@color/home_cta_text</item>
        <item name="cornerRadius">28dp</item>
        <item name="elevation">10dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.ReservasApp.Button.Home.Primary" parent="Widget.ReservasApp.Button.Home">
        <item name="backgroundTint">@color/home_cta_primary_fill</item>
    </style>

    <style name="Widget.ReservasApp.Button.Home.Secondary" parent="Widget.ReservasApp.Button.Home">
        <item name="backgroundTint">@color/home_cta_secondary_fill</item>
    </style>
</resources>
