<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.App.Light" parent="Theme.Material3.NoActionBar">
        <item name="android:colorBackground">@color/app_light_background</item>
        <item name="colorBackground">@color/app_light_background</item>
        <item name="colorOnBackground">@color/app_light_on_background</item>
        <item name="colorSurface">@color/app_light_surface</item>
        <item name="colorOnSurface">@color/app_light_on_surface</item>
        <item name="android:statusBarColor">@color/app_light_surface</item>
        <item name="android:navigationBarColor">@color/app_light_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.App.Dark" parent="Theme.Material3.NoActionBar">
        <item name="android:colorBackground">@color/app_dark_background</item>
        <item name="colorBackground">@color/app_dark_background</item>
        <item name="colorOnBackground">@color/app_dark_on_background</item>
        <item name="colorSurface">@color/app_dark_surface</item>
        <item name="colorOnSurface">@color/app_dark_on_surface</item>
        <item name="android:statusBarColor">@color/app_dark_surface</item>
        <item name="android:navigationBarColor">@color/app_dark_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.App" parent="Theme.App.Light" />
    <style name="Theme.ReservasApp" parent="Theme.App" />
</resources>
